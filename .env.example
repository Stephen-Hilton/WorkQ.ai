# =============================================================================
# WorkQ.ai — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in. `.env` is gitignored.
#
# These values are deploy *inputs*. Deploy *outputs* (api_url, cognito IDs,
# etc.) are written by `sam deploy` to `.workq.outputs.json` (also gitignored).
#
# All vars are prefixed WORKQ_ to avoid collisions.

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
# Region must be us-east-1 if you use a custom domain (CloudFront cert
# constraint).
WORKQ_AWS_REGION=us-east-1

# Use either a profile from ~/.aws/credentials...
#WORKQ_AWS_PROFILE=default

# ...or explicit keys. The standard AWS SDK credential chain applies.
#WORKQ_AWS_ACCESS_KEY_ID=
#WORKQ_AWS_SECRET_ACCESS_KEY=

# Stack name for SAM. Lowercase + hyphens.
WORKQ_STACK_NAME=workq

# -----------------------------------------------------------------------------
# Custom domain (optional)
# -----------------------------------------------------------------------------
# If set, the webapp deploys to https://work.<domain> and the API to
# https://api.<domain>. Otherwise both fall back to AWS-default URLs.
#WORKQ_CUSTOM_DOMAIN=example.com

# Required if WORKQ_CUSTOM_DOMAIN is set. Single ACM cert ARN in us-east-1
# covering BOTH `work.<domain>` and `api.<domain>` (wildcard `*.<domain>` or SAN).
#WORKQ_CUSTOM_DOMAIN_CERT_ARN=arn:aws:acm:us-east-1:123456789012:certificate/...

# -----------------------------------------------------------------------------
# Cognito email whitelist
# -----------------------------------------------------------------------------
# Comma-separated. Entries starting with `@` match the whole domain.
# This value is used to *seed* the SSM parameter on first deploy. After that,
# manage the whitelist via `scripts/whitelist_user.sh`.
WORKQ_EMAIL_WHITELIST=@example.com

# -----------------------------------------------------------------------------
# GitHub (used by local/build)
# -----------------------------------------------------------------------------
# Repo claude code will operate on.
WORKQ_GITHUB_REPO_URL=https://github.com/yourorg/yourrepo.git

# Default base branch.
WORKQ_GITHUB_BRANCH=main

# Fine-grained PAT with at minimum:
#   - contents:write (push branches)
#   - pull_requests:write (create PRs)
# If WORKQ_GITHUB_AUTO_MERGE=true, also needs admin rights on the repo.
WORKQ_GITHUB_TOKEN=

# Auto-merge every PR immediately after creation. Default false.
# Use only for fluid early-stage projects where speed > review.
WORKQ_GITHUB_AUTO_MERGE=false

# squash | merge | rebase. Only used if auto-merge is on.
WORKQ_GITHUB_AUTO_MERGE_METHOD=squash

# -----------------------------------------------------------------------------
# Local server
# -----------------------------------------------------------------------------
# Monitor poll interval, in seconds.
WORKQ_POLLING_SECONDS=30

# Max wall-clock time for a single claude run, in seconds. 2700 = 45 min.
WORKQ_BUILD_TIMEOUT_SECONDS=2700

# Path on disk to the prompt_parts.yaml file. Read by local/build only;
# the webapp gets a derived payload via app.json (see config/README.md).
WORKQ_PROMPT_PARTS_PATH=./config/prompt_parts.yaml

# -----------------------------------------------------------------------------
# Webapp display
# -----------------------------------------------------------------------------
# Display-only timezone (storage is always UTC). Use abbreviations from
# https://en.wikipedia.org/wiki/List_of_time_zone_abbreviations
# This value is published to S3 as part of the runtime config.
WORKQ_DISPLAY_TIMEZONE=UTC
