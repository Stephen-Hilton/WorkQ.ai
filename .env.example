# =============================================================================
# RequestQueue.ai — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in. `.env` is gitignored.
#
# These values are deploy *inputs*. Deploy *outputs* (api_url, cognito IDs,
# etc.) are written by `sam deploy` to `.requestqueue.outputs.json` (also gitignored).
#
# All vars are prefixed REQUESTQUEUE_ to avoid collisions.

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
# Region must be us-east-1 if you use a custom domain (CloudFront cert
# constraint). Set this either as REQUESTQUEUE_AWS_REGION here, or as the
# default in `aws configure`. The deploy/bootstrap scripts auto-export this
# to the standard AWS_REGION / AWS_DEFAULT_REGION used by the aws CLI.
REQUESTQUEUE_AWS_REGION=us-east-1

# Provide credentials via ONE of:
#   1. A named profile (recommended): run `aws configure --profile <name>`
#      once, then set REQUESTQUEUE_AWS_PROFILE=<name>. The scripts export
#      this as AWS_PROFILE for the aws CLI.
#REQUESTQUEUE_AWS_PROFILE=requestqueue
#
#   2. Explicit access keys (less secure — anyone with .env has the keys):
#REQUESTQUEUE_AWS_ACCESS_KEY_ID=
#REQUESTQUEUE_AWS_SECRET_ACCESS_KEY=
#REQUESTQUEUE_AWS_SESSION_TOKEN=          # only if using temp/STS creds
#
#   3. Nothing here, and rely on the default `aws configure` profile or an
#      EC2/ECS instance role. Standard AWS SDK credential chain applies.
#
# Note: any value already set in the shell as AWS_* takes precedence over
# the REQUESTQUEUE_AWS_* equivalent.

# Stack name for SAM. Lowercase + hyphens.
REQUESTQUEUE_STACK_NAME=requestqueue

# -----------------------------------------------------------------------------
# Custom domain (optional)
# -----------------------------------------------------------------------------
# If set, the webapp deploys to https://<WEBAPP_SUBDOMAIN>.<CUSTOM_DOMAIN> and
# the API to https://<API_SUBDOMAIN>.<CUSTOM_DOMAIN>. Default subdomains are
# `work` and `api`, so `REQUESTQUEUE_CUSTOM_DOMAIN=example.com` alone gives you
# work.example.com + api.example.com. Override the subdomains below for any
# other layout (e.g. WEBAPP=workq, API=api.workq for workq.example.com +
# api.workq.example.com). Otherwise both fall back to AWS-default URLs.
#REQUESTQUEUE_CUSTOM_DOMAIN=example.com

# Required if REQUESTQUEUE_CUSTOM_DOMAIN is set. Single ACM cert ARN in
# us-east-1 covering BOTH the webapp and API hostnames as configured below
# (wildcard `*.<domain>` works for the default `work`/`api` layout; for
# multi-label subdomains use specific SANs).
#REQUESTQUEUE_CUSTOM_DOMAIN_CERT_ARN=arn:aws:acm:us-east-1:123456789012:certificate/...

# Optional subdomain overrides. Default = `work` / `api`. Can be multi-label
# (dots allowed) for nested layouts. Only honored when CUSTOM_DOMAIN is set.
#REQUESTQUEUE_WEBAPP_SUBDOMAIN=work
#REQUESTQUEUE_API_SUBDOMAIN=api

# -----------------------------------------------------------------------------
# Cognito email whitelist
# -----------------------------------------------------------------------------
# Comma-separated. Entries starting with `@` match the whole domain.
# This value is used to *seed* the SSM parameter on first deploy. After that,
# manage the whitelist via `scripts/whitelist_user.sh`.
REQUESTQUEUE_EMAIL_WHITELIST=@example.com

# -----------------------------------------------------------------------------
# GitHub (used by local/build)
# -----------------------------------------------------------------------------
# Repo claude code will operate on.
REQUESTQUEUE_GITHUB_REPO_URL=https://github.com/yourorg/yourrepo.git

# Default base branch.
REQUESTQUEUE_GITHUB_BRANCH=main

# Optional. If set, used by `local/build` for git push + `gh pr create` —
# overrides any ambient `gh auth login` keyring credentials. **Leave empty if
# the machine running `make monitor` has already run `gh auth login`** (most
# common case): git/gh inherit the keyring auth and push/PR-create work with
# no explicit token. Set this only for headless / cross-machine deploys where
# `gh auth login` isn't viable.
#
# Fine-grained PAT scopes (when used):
#   - contents:write (push branches)
#   - pull_requests:write (create PRs)
# If REQUESTQUEUE_GITHUB_AUTO_MERGE=true, also needs admin rights on the repo.
REQUESTQUEUE_GITHUB_TOKEN=

# Auto-merge every PR immediately after creation. Default false.
# Use only for fluid early-stage projects where speed > review.
REQUESTQUEUE_GITHUB_AUTO_MERGE=false

# squash | merge | rebase. Only used if auto-merge is on.
REQUESTQUEUE_GITHUB_AUTO_MERGE_METHOD=squash

# -----------------------------------------------------------------------------
# Local server
# -----------------------------------------------------------------------------
# Monitor poll interval, in seconds.
REQUESTQUEUE_POLLING_SECONDS=30

# Max wall-clock time for a single claude run, in seconds. 2700 = 45 min.
REQUESTQUEUE_BUILD_TIMEOUT_SECONDS=2700

# Path on disk to the prompt_parts.yaml file. Read by local/build only;
# the webapp gets a derived payload via app.json (see config/README.md).
REQUESTQUEUE_PROMPT_PARTS_PATH=./config/prompt_parts.yaml

# -----------------------------------------------------------------------------
# Webapp display
# -----------------------------------------------------------------------------
# Display-only timezone (storage is always UTC). Use abbreviations from
# https://en.wikipedia.org/wiki/List_of_time_zone_abbreviations
# This value is published to S3 as part of the runtime config.
REQUESTQUEUE_DISPLAY_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Cognito service-user credentials
# -----------------------------------------------------------------------------
# These authenticate the local server's monitor + build processes to the API
# (the webapp uses your personal Cognito login; this is the machine equivalent).
#
# Generate / rotate via:
#     scripts/refresh_creds.sh
# which writes both lines below into THIS file (with a backup).
#
# If you run the deploy machine and the local server on different boxes:
# after running refresh_creds.sh on the deploy machine, copy these two lines
# into the local server's .env so it can authenticate. Then `make publish` to
# apply the new password to the Cognito user pool.
#
# Don't edit by hand. The values below are placeholders and will be overwritten.
REQUESTQUEUE_SERVICE_USER_EMAIL=
REQUESTQUEUE_SERVICE_USER_PASSWORD=
